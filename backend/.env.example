# ==== Serveur ====
PORT=5000
CLIENT_URL=http://localhost:5173

# ==== Base de données ====
# dialect: sqlite (par défaut, aucune config requise) ou postgres
DB_DIALECT=sqlite
DB_STORAGE=./data/database.sqlite

# Utilisé seulement si DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=messagerie
DB_USER=postgres
DB_PASSWORD=postgres

# ==== Sécurité ====
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# ==== Compte administrateur initial (créé via npm run seed:admin) ====
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMoi123!

# ==== Système d'adhésion sur invitation ====
# Si true, toute nouvelle inscription nécessite un lien d'invitation valide
INVITE_ONLY=true

# ==== Module de paiement (activable / désactivable) ====
PAYMENT_ENABLED=false
# provider: stripe | paypal | mobilemoney
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
MOBILEMONEY_API_KEY=
MOBILEMONEY_API_URL=
